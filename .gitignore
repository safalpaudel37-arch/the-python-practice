# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.sample

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/questions
questions/*

# media / binary assets
*.webm
*.mp4
*.mov

# dev utility scripts
screenshot.mjs
/scripts/

# local-only admin pages (never ship to production)
/src/app/admin/

# claude code local settings
.claude/settings.local.json
.claude/worktrees/