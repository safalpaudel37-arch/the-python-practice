# ─────────────────────────────────────────────
# Supabase — required for all environments
# ─────────────────────────────────────────────

# Your Supabase project URL
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous (public) key — safe to use client-side
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─────────────────────────────────────────────
# Admin / development only
# These are NOT needed in production and should
# NOT be set in your hosting platform's env vars.
# ─────────────────────────────────────────────

# Supabase service role key — server-side only, never sent to the browser
# Required only for the bulk question insert endpoint (POST /api/admin/add-questions)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Arbitrary secret to authenticate admin endpoints
# Set to any random string (e.g. openssl rand -base64 32)
ADMIN_SECRET=your-admin-secret

# ─────────────────────────────────────────────
# AI hints — optional
# Leave empty (or omit) to disable the hint button
# ─────────────────────────────────────────────

# Google Gemini Flash API key (free tier available)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
