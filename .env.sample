# ─────────────────────────────────────────────
# Supabase — required for all environments
# ─────────────────────────────────────────────

# Your Supabase project URL
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous (public) key — safe to use client-side
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─────────────────────────────────────────────
# Admin / development only
# These are NOT needed in production and should
# NOT be set in your hosting platform's env vars.
# ─────────────────────────────────────────────

# Supabase service role key — server-side only, never sent to the browser
# Required only for the bulk question insert endpoint (POST /api/admin/add-questions)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Arbitrary secret to authenticate admin endpoints
# Set to any random string (e.g. openssl rand -base64 32)
ADMIN_SECRET=your-admin-secret

# ─────────────────────────────────────────────
# AI hints — optional
# Leave empty (or omit) to disable the hint button
# ─────────────────────────────────────────────

# OpenRouter API key — powers the hint button (server-side only, never sent to the browser)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: override the model used for hints. Defaults to a cheap, reliable model.
# Examples: meta-llama/llama-3.3-70b-instruct, deepseek/deepseek-chat, qwen/qwen-2.5-coder-32b-instruct
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Optional: your deployed site URL, sent to OpenRouter for dashboard attribution
# OPENROUTER_SITE_URL=https://your-app-url.com

# Prisma — Postgres connection (Supavisor session pooler; the direct db.*.supabase.co
# host is IPv6-only). Find it in Supabase → Settings → Database → Connection string.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Comma-separated emails that get the ADMIN role on first sign-in (admin dashboard access):
ADMIN_EMAILS=
